rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    // App-wide allowlist. One empty doc per allowed uid at /allowlist/{uid};
    // exists() works here without any allow-read rule on that collection, so
    // the list is never exposed to clients. This now gates only trip CREATION
    // and legacy data — it stops un-invited randoms from using this Firebase
    // project as free storage. Trip PARTICIPATION (reading/joining/editing a
    // trip you belong to) is gated by trip MEMBERSHIP, not this list, so that
    // invited friends can join via the approval flow without being pre-added.
    function isAllowedUser() {
      return signedIn() && exists(/databases/$(database)/documents/allowlist/$(request.auth.uid));
    }

    // Legacy per-user data — kept so client-side migration can read/delete it.
    match /users/{uid}/{document=**} {
      allow read, write: if isAllowedUser() && request.auth.uid == uid;
    }

    // Safe pre-join preview: name/destination/dates/member names+ids only —
    // deliberately no email/photoURL/phone/budget, see buildPreview() in
    // firestore.ts. Any signed-in user with the trip id may read it (invite
    // links resolve to this so an invitee can see what they're requesting to
    // join, without exposing member PII; trip ids are unguessable UUIDs, so
    // exposure is bounded to link-holders). Only a current trip member may
    // write/refresh it, checked against the authoritative trip doc — this
    // write always follows the real trip write, never precedes it, so the
    // membership it checks is already committed.
    match /tripsPreview/{tripId} {
      allow get: if signedIn();
      allow write: if signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberUids;
    }

    match /trips/{tripId} {
      function isMember() { return signedIn() && request.auth.uid in resource.data.memberUids; }

      // `members` may grow (append) but an existing entry's fields
      // (name/uid/email/photoURL) may never be altered by this path —
      // otherwise any member could rewrite another member's identity.
      function isMembersGrowthOnly(oldMembers, newMembers) {
        return newMembers.size() >= oldMembers.size() && newMembers.hasAll(oldMembers);
      }

      // Full trip doc (incl. member email/photoURL) is members-only. Non-members
      // with an invite link read the PII-free tripsPreview instead. Joining is
      // never a direct write here — it goes through joinRequests + owner approval.
      allow get: if isMember();
      allow list: if isMember();

      allow create: if isAllowedUser()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids == [request.auth.uid];

      // Only the owner or an existing member may update. memberUids can grow
      // only via the owner (who adds an approved requester); a non-owner member
      // may edit trip fields and append offline members but must leave memberUids
      // byte-identical and never alter an existing member entry in place. There
      // is no self-join path — non-members cannot write to the trip at all.
      allow update: if signedIn()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          request.auth.uid == resource.data.ownerUid
          || (isMember()
              && request.resource.data.memberUids == resource.data.memberUids
              && isMembersGrowthOnly(resource.data.members, request.resource.data.members))
        );

      allow delete: if signedIn() && request.auth.uid == resource.data.ownerUid;

      // Pending requests to join, keyed by requester uid (one per user). Any
      // signed-in user with the trip id may create/read/delete THEIR OWN
      // request — this is how a non-allowlisted invitee asks to be let in. The
      // owner lists all requests and, on approval, performs the member-add
      // write above (they're the owner) then deletes the request.
      match /joinRequests/{reqUid} {
        function reqTrip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }
        // Shape/size caps: the only attacker-controlled write a non-member can
        // make, and its fields flow into the owner's UI and members[] on
        // approval — bound them (escaping stays client-side).
        function validReq(d) {
          return d.keys().hasOnly(['uid', 'name', 'email', 'photoURL', 'claimMemberId', 'requestedAt'])
            && d.uid == request.auth.uid
            && d.name is string && d.name.size() <= 100
            && (!('email' in d) || d.email == null || (d.email is string && d.email.size() <= 200))
            && (!('photoURL' in d) || d.photoURL == null || (d.photoURL is string && d.photoURL.size() <= 500))
            && (!('claimMemberId' in d) || (d.claimMemberId is string && d.claimMemberId.size() <= 64))
            && d.requestedAt is string && d.requestedAt.size() <= 30;
        }
        allow create, update: if signedIn()
          && reqUid == request.auth.uid
          && validReq(request.resource.data)
          && !(request.auth.uid in reqTrip().memberUids);
        allow get: if signedIn()
          && (reqUid == request.auth.uid || request.auth.uid == reqTrip().ownerUid);
        allow list: if signedIn() && request.auth.uid == reqTrip().ownerUid;
        allow delete: if signedIn()
          && (reqUid == request.auth.uid || request.auth.uid == reqTrip().ownerUid);
      }

      match /expenses/{expenseId} {
        function trip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }

        // Server-side mirror of AddExpenseForm's client validation — a member
        // writing via the SDK directly (bypassing the UI) can't corrupt
        // balance/settlement math with negative/absurd amounts or a doc
        // pointing at some other trip. Rules can't sum splitAmounts (no
        // reduce), so the splits-equal-total invariant stays client-only.
        function isValidExpense(exp) {
          return exp.id == expenseId
            && exp.tripId == tripId
            && exp.amount is number
            && exp.amount > 0
            && exp.amount <= 9999999
            && exp.category in ['food', 'transport', 'accommodation', 'activities', 'shopping', 'custom']
            && exp.paidBy is string && exp.paidBy.size() > 0
            && exp.splitBetween is list && exp.splitBetween.size() > 0
            && exp.date is string && exp.date.size() == 10
            && exp.notes is string && exp.notes.size() <= 200
            && (!('customCategory' in exp) || (exp.customCategory is string && exp.customCategory.size() <= 50))
            && (!('splitAmounts' in exp) || exp.splitAmounts is list)
            && (!('receiptPhotoUrl' in exp) || exp.receiptPhotoUrl is string);
        }

        allow read: if request.auth.uid in trip().memberUids;
        // New expenses must be stamped with the creator's own uid
        allow create: if request.auth.uid in trip().memberUids
          && request.resource.data.createdByUid == request.auth.uid
          && isValidExpense(request.resource.data);
        // Only the expense's creator (or the trip owner) may edit/delete it,
        // and the creator stamp cannot be reassigned
        allow update: if request.resource.data.createdByUid == resource.data.createdByUid
          && isValidExpense(request.resource.data)
          && (request.auth.uid == trip().ownerUid
              || (request.auth.uid in trip().memberUids
                  && resource.data.createdByUid == request.auth.uid));
        allow delete: if request.auth.uid == trip().ownerUid
          || (request.auth.uid in trip().memberUids
              && resource.data.createdByUid == request.auth.uid);
      }

      // Append-only activity feed: members read and add entries stamped with
      // their own uid; nothing is edited. Owner may delete (trip cleanup).
      match /activity/{activityId} {
        function actTrip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }
        allow read: if request.auth.uid in actTrip().memberUids;
        allow create: if request.auth.uid in actTrip().memberUids
          && request.resource.data.actorUid == request.auth.uid;
        allow delete: if request.auth.uid == actTrip().ownerUid;
      }
    }
  }
}
