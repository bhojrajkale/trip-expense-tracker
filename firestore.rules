rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy per-user data — kept so client-side migration can read/delete it.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /trips/{tripId} {
      function signedIn() { return request.auth != null; }
      function isMember() { return signedIn() && request.auth.uid in resource.data.memberUids; }

      // Capability-URL: any signed-in user who has the trip id (i.e. the
      // invite link) may GET that one trip — powers the Join preview so
      // invitees see what they're joining. Queries (list) only ever return
      // trips you are a member of, so trips never leak in bulk.
      allow get: if signedIn();
      allow list: if isMember();

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // Owner: full control (except ownerUid is immutable).
      // Members and joiners: may edit trip fields and ADD members, but never
      // remove one — every existing memberUid must be preserved and the
      // members array may only grow. Join is the same rule: a non-member's
      // only valid update adds their own uid.
      allow update: if signedIn()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          request.auth.uid == resource.data.ownerUid
          || (request.resource.data.memberUids.hasAll(resource.data.memberUids)
              && request.auth.uid in request.resource.data.memberUids
              && request.resource.data.members.size() >= resource.data.members.size())
        );

      allow delete: if signedIn() && request.auth.uid == resource.data.ownerUid;

      match /expenses/{expenseId} {
        function trip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }
        allow read: if request.auth != null && request.auth.uid in trip().memberUids;
        // New expenses must be stamped with the creator's own uid
        allow create: if request.auth != null
          && request.auth.uid in trip().memberUids
          && request.resource.data.createdByUid == request.auth.uid;
        // Only the expense's creator (or the trip owner) may edit/delete it,
        // and the creator stamp cannot be reassigned
        allow update: if request.auth != null
          && request.resource.data.createdByUid == resource.data.createdByUid
          && (request.auth.uid == trip().ownerUid
              || (request.auth.uid in trip().memberUids
                  && resource.data.createdByUid == request.auth.uid));
        allow delete: if request.auth != null
          && (request.auth.uid == trip().ownerUid
              || (request.auth.uid in trip().memberUids
                  && resource.data.createdByUid == request.auth.uid));
      }
    }
  }
}
