rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    // App-wide allowlist. Mirrors VITE_ALLOWED_UIDS (client-side gate is UX
    // only — this is the actual enforcement). One empty doc per allowed uid
    // at /allowlist/{uid}; exists() works here without any allow-read rule
    // on that collection, so the list is never exposed to clients.
    function isAllowedUser() {
      return signedIn() && exists(/databases/$(database)/documents/allowlist/$(request.auth.uid));
    }

    // Legacy per-user data — kept so client-side migration can read/delete it.
    match /users/{uid}/{document=**} {
      allow read, write: if isAllowedUser() && request.auth.uid == uid;
    }

    // Safe pre-join preview: name/destination/dates/member names+ids only —
    // deliberately no email/photoURL/phone/budget, see buildPreview() in
    // firestore.ts. Any allowlisted signed-in user may read it (this is
    // what invite links resolve to before the viewer decides to join,
    // without exposing member PII). Only a current trip member may
    // write/refresh it, checked against the authoritative trip doc — this
    // write always follows the real trip write, never precedes it, so the
    // membership it checks is already committed.
    match /tripsPreview/{tripId} {
      allow get: if isAllowedUser();
      allow write: if isAllowedUser()
        && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberUids;
    }

    match /trips/{tripId} {
      function isMember() { return signedIn() && request.auth.uid in resource.data.memberUids; }

      // `members` may grow (append) but an existing entry's fields
      // (name/uid/email/photoURL) may never be altered by this path —
      // otherwise any member could rewrite another member's identity.
      function isMembersGrowthOnly(oldMembers, newMembers) {
        return newMembers.size() >= oldMembers.size() && newMembers.hasAll(oldMembers);
      }

      // Join-by-claim: exactly one existing "offline" (no uid) entry is
      // replaced by the same entry now carrying the joiner's own uid —
      // every other entry, and the entry's id, must stay untouched.
      function isValidClaim(oldMembers, newMembers, uid) {
        let removed = oldMembers.removeAll(newMembers);
        let added = newMembers.removeAll(oldMembers);
        return newMembers.size() == oldMembers.size()
          && removed.size() == 1
          && added.size() == 1
          && added[0].id == removed[0].id
          && added[0].uid == uid
          && !('uid' in removed[0]);
      }

      // Capability-URL: any allowed, signed-in user who has the trip id may
      // GET that one trip — this is now only exercised by the deliberate
      // "claim an existing member" join action (see getTripForClaim() in
      // firestore.ts), which needs full member fidelity to safely rewrite
      // the array. The common join-preview path reads tripsPreview instead
      // (below) and never touches this document. Queries (list) only ever
      // return trips you belong to.
      allow get: if isAllowedUser();
      allow list: if isAllowedUser() && isMember();

      allow create: if isAllowedUser()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids == [request.auth.uid];

      // memberUids may only ever change by a self-join appending exactly the
      // caller's own uid — never an arbitrary third-party uid, and never as
      // a side effect of an unrelated field edit. This is what actually
      // grants Firestore read/write access to a trip's expenses, so it's
      // tightened independently of the (looser) `members` display list.
      allow update: if isAllowedUser()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (
          // Owner: full control, including membership revocation and
          // correcting member details.
          request.auth.uid == resource.data.ownerUid
          // Existing member editing trip fields / adding an offline member:
          // memberUids must stay byte-for-byte identical; members may only
          // grow, and no existing member's entry may be altered in place.
          || (isMember()
              && request.resource.data.memberUids == resource.data.memberUids
              && isMembersGrowthOnly(resource.data.members, request.resource.data.members))
          // Self-join: caller adds ONLY themself to memberUids, and either
          // appends a brand-new member entry or claims exactly one existing
          // unclaimed entry as their own — no other member's data changes.
          || (!isMember()
              && request.resource.data.memberUids == resource.data.memberUids.concat([request.auth.uid])
              && (
                isMembersGrowthOnly(resource.data.members, request.resource.data.members)
                || isValidClaim(resource.data.members, request.resource.data.members, request.auth.uid)
              ))
        );

      allow delete: if isAllowedUser() && request.auth.uid == resource.data.ownerUid;

      match /expenses/{expenseId} {
        function trip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }

        // Server-side mirror of AddExpenseForm's client validation — a member
        // writing via the SDK directly (bypassing the UI) can't corrupt
        // balance/settlement math with negative/absurd amounts or a doc
        // pointing at some other trip. Rules can't sum splitAmounts (no
        // reduce), so the splits-equal-total invariant stays client-only.
        function isValidExpense(exp) {
          return exp.id == expenseId
            && exp.tripId == tripId
            && exp.amount is number
            && exp.amount > 0
            && exp.amount <= 9999999
            && exp.category in ['food', 'transport', 'accommodation', 'activities', 'shopping', 'custom']
            && exp.paidBy is string && exp.paidBy.size() > 0
            && exp.splitBetween is list && exp.splitBetween.size() > 0
            && exp.date is string && exp.date.size() == 10
            && exp.notes is string && exp.notes.size() <= 200
            && (!('customCategory' in exp) || (exp.customCategory is string && exp.customCategory.size() <= 50))
            && (!('splitAmounts' in exp) || exp.splitAmounts is list)
            && (!('receiptPhotoUrl' in exp) || exp.receiptPhotoUrl is string);
        }

        allow read: if isAllowedUser() && request.auth.uid in trip().memberUids;
        // New expenses must be stamped with the creator's own uid
        allow create: if isAllowedUser()
          && request.auth.uid in trip().memberUids
          && request.resource.data.createdByUid == request.auth.uid
          && isValidExpense(request.resource.data);
        // Only the expense's creator (or the trip owner) may edit/delete it,
        // and the creator stamp cannot be reassigned
        allow update: if isAllowedUser()
          && request.resource.data.createdByUid == resource.data.createdByUid
          && isValidExpense(request.resource.data)
          && (request.auth.uid == trip().ownerUid
              || (request.auth.uid in trip().memberUids
                  && resource.data.createdByUid == request.auth.uid));
        allow delete: if isAllowedUser()
          && (request.auth.uid == trip().ownerUid
              || (request.auth.uid in trip().memberUids
                  && resource.data.createdByUid == request.auth.uid));
      }

      // Append-only activity feed: members read and add entries stamped with
      // their own uid; nothing is edited. Owner may delete (trip cleanup).
      match /activity/{activityId} {
        function actTrip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }
        allow read: if isAllowedUser() && request.auth.uid in actTrip().memberUids;
        allow create: if isAllowedUser()
          && request.auth.uid in actTrip().memberUids
          && request.resource.data.actorUid == request.auth.uid;
        allow delete: if isAllowedUser() && request.auth.uid == actTrip().ownerUid;
      }
    }
  }
}
